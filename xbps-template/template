# ── Build ──────────────────────────────────────────────────────────
# python3-module: otomatis handle build + install via pip
# Entry point /usr/bin/letx dibuat otomatis dari [project.scripts]
# di pyproject.toml — tidak perlu wrapper manual
build_style=python3-module

# python3-hatchling TIDAK ada di Void repo → pakai setuptools
hostmakedepends="python3 python3-setuptools python3-wheel python3-pip"

# Runtime deps — python3-typer TIDAK ada di Void repo
# argparse sudah built-in Python stdlib
depends="python3 python3-httpx python3-rich"

# ── Post install ───────────────────────────────────────────────────
post_install() {
	vlicense LICENSE
	vdoc README.md

	# Man page opsional
	if [ -f letx.1 ]; then
		vman letx.1
	fi
}
