# Template for 'Let-X'
pkgname=letx
version=0.1.1
revision=1
short_desc="VUR Helper for Void Linux"
maintainer="Gh0sT4n <darskevoid@gmail.com>"
license="BSD-2-Clause"
homepage="https://github.com/T4n-Labs/Let-X"
distfiles="https://github.com/T4n-Labs/Let-X/archive/refs/tags/v${version}.tar.gz"
checksum=44a1229f9be720d155b1dbad3a944cec75bf61be585f810ddd3ff62bc3a027fa

# ── Dependencies ───────────────────────────────────────────────────
# Tidak pakai build_style=python3-module karena masih memanggil
# 'python3 setup.py build' — tidak kompatibel dengan pyproject.toml murni
# Build manual via pip langsung

hostmakedepends="python3 python3-pip python3-setuptools python3-wheel"

# argparse sudah built-in Python stdlib
depends="python3 python3-httpx python3-rich"

# ── Build ──────────────────────────────────────────────────────────
do_build() {
	python3 -m pip wheel \
		--no-build-isolation \
		--no-deps \
		--wheel-dir dist \
		.
}

# ── Install ────────────────────────────────────────────────────────
do_install() {
	python3 -m pip install \
		--no-build-isolation \
		--no-deps \
		--no-index \
		--prefix=/usr \
		--root="${DESTDIR}" \
		dist/*.whl

	vlicense LICENSE
	vdoc README.md

	if [ -f letx.1 ]; then
		vman letx.1
	fi
}
